Day 1 
1. Linked List Cycle 

class Solution {
public:
    bool hasCycle(ListNode *head) {
        
        ListNode* first = head;
        ListNode* second = head;

        while (first != nullptr && first->next != nullptr) {
            first = first->next->next;
            second = second->next;

            if (first == second) {
                return true;
            }
        }

        return false;        
    }
};
   
